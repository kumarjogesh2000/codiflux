# .gitattributes — Git file handling rules
# Ensures consistent line endings and correct file classification.

# ── Default: Normalize all text files to LF ─────────────────────
* text=auto eol=lf

# ── Source Files ─────────────────────────────────────────────────
*.astro   text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.mjs     text eol=lf
*.cjs     text eol=lf
*.json    text eol=lf
*.css     text eol=lf
*.html    text eol=lf
*.md      text eol=lf
*.mdx     text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.toml    text eol=lf
*.txt     text eol=lf

# ── Binary Files — Never mangle these ───────────────────────────
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.webp    binary
*.avif    binary
*.svg     text eol=lf
*.ico     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.otf     binary
*.eot     binary
*.pdf     binary
*.zip     binary
*.gz      binary

# ── GitHub Language Detection ────────────────────────────────────
# Exclude generated/config files from repo language statistics.
package-lock.json       linguist-generated=true
*.min.js                linguist-generated=true
*.min.css               linguist-generated=true
dist/**                 linguist-generated=true
.astro/**               linguist-generated=true
