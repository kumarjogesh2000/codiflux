# .env.example — CodiFlux Environment Variable Reference
#
# Copy this file to .env.local and fill in the values.
# NEVER commit .env or .env.local to version control.
#
# Note: This is a static Astro site. All env vars prefixed with
# PUBLIC_ are exposed to the browser. Never put secrets in PUBLIC_ vars.
#
# Current deployment: Hostinger static hosting (no server runtime).
# If migrating to SSR, additional server-only vars can be added here.

# ── Site Configuration ───────────────────────────────────────────
# Override the production URL for local/staging previews.
# PUBLIC_SITE_URL=https://codiflux.dev

# ── Analytics (future) ──────────────────────────────────────────
# Plausible Analytics
# PUBLIC_PLAUSIBLE_DOMAIN=codiflux.dev

# Google Analytics 4
# PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Contact Form (future) ────────────────────────────────────────
# Formspree endpoint ID (if using Formspree for contact form)
# PUBLIC_FORMSPREE_ID=xxxxxxxxxxx

# EmailJS credentials (if using EmailJS)
# PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
# PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
# PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxx

# ── Content Management (future) ──────────────────────────────────
# If migrating to a headless CMS (e.g. Contentful, Sanity)
# CONTENTFUL_SPACE_ID=
# CONTENTFUL_ACCESS_TOKEN=
# SANITY_PROJECT_ID=
# SANITY_DATASET=
