---
/**
 * Nav.astro
 * Desktop navigation links.
 * Renders anchor elements from the NAV_ITEMS constant.
 * Mobile navigation is handled separately by MobileMenu.tsx (React).
 */
import { NAV_ITEMS } from '@/lib/constants';
import { cn } from '@/lib/utils';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
---

<nav aria-label="Primary navigation">
  <ul role="list" class="flex items-center gap-1">
    {NAV_ITEMS.map((item) => {
      const isActive = currentPath === item.href || currentPath.startsWith(`${item.href}/`);
      return (
        <li>
          <a
            href={item.href}
            class={cn(
              'relative px-3 py-2 text-sm font-medium rounded-md transition-colors duration-150',
              'hover:text-white hover:bg-white/5',
              isActive
                ? 'text-white'
                : 'text-[var(--color-text-secondary)]'
            )}
            aria-current={isActive ? 'page' : undefined}
          >
            {item.label}
            {isActive && (
              <span
                class="absolute inset-x-1 -bottom-px h-px bg-brand-500"
                aria-hidden="true"
              />
            )}
          </a>
        </li>
      );
    })}
  </ul>
</nav>
