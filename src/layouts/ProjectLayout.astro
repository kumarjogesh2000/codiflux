---
/**
 * ProjectLayout.astro
 * Layout for individual portfolio project case study pages (/portfolio/[slug]).
 *
 * Extends PageLayout with project-specific meta:
 * - ogType set to 'article'
 * - Cover image as OG image
 * - Structured data for the project (CreativeWork schema)
 */
import PageLayout from './PageLayout.astro';

interface Props {
  title: string;
  description: string;
  coverImage?: string;
}

const { title, description, coverImage } = Astro.props;
---

<PageLayout
  title={title}
  description={description}
  ogImage={coverImage}
  ogType="article"
>
  <slot />
</PageLayout>
