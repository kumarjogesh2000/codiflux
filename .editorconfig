# .editorconfig — https://editorconfig.org
# Ensures consistent coding style across all editors and IDEs.

root = true

# ── All Files ──────────────────────────────────────────────────
[*]
charset                  = utf-8
end_of_line              = lf
indent_style             = space
indent_size              = 2
insert_final_newline     = true
trim_trailing_whitespace = true
max_line_length          = 100

# ── Markdown ────────────────────────────────────────────────────
# Trailing whitespace is significant in Markdown (line breaks).
[*.md]
trim_trailing_whitespace = false
max_line_length          = off

# ── JSON / YAML ─────────────────────────────────────────────────
[*.{json,yaml,yml}]
indent_size = 2

# ── Package Lock ────────────────────────────────────────────────
# Auto-generated — don't enforce style rules.
[package-lock.json]
indent_size = unset
