---
/**
 * 404.astro — Custom Not Found Page
 * Shown when a user navigates to a non-existent route.
 * Uses BaseLayout (no header/footer distraction) for focused messaging.
 */
import PageLayout from '@/layouts/PageLayout.astro';
---

<PageLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist. Let's get you back on track."
  noIndex={true}
>
  <section class="container section-padding flex flex-col items-center justify-center min-h-[60vh] text-center">
    <span class="text-8xl font-black gradient-text" aria-hidden="true">404</span>
    <h1 class="mt-4 text-2xl font-bold text-[var(--color-text-primary)]">
      Page not found
    </h1>
    <p class="mt-3 text-[var(--color-text-secondary)] max-w-md">
      The page you were looking for doesn't exist or may have moved.
    </p>
    <div class="mt-8 flex flex-col sm:flex-row items-center gap-3">
      <a
        href="/"
        class="px-5 py-2.5 rounded-md bg-brand-600 hover:bg-brand-700 text-white
               text-sm font-medium transition-colors duration-150"
      >
        Back to Home
      </a>
      <a
        href="/contact"
        class="px-5 py-2.5 rounded-md border border-[var(--color-border-base)]
               text-[var(--color-text-secondary)] hover:text-white hover:border-[var(--color-border-strong)]
               text-sm font-medium transition-colors duration-150"
      >
        Contact Us
      </a>
    </div>
  </section>
</PageLayout>
